<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#111113">
<title>Scribble</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #111113; --surface: #1c1c1e; --border: #2a2a2e; --border2: #3a3a3f;
  --text: #f0f0ee; --muted: #6b6b72; --accent: #4f8ef7; --accent-light: #151e30;
  --green: #34d399; --green-light: #0c2118; --red: #f87171;
  --yellow: #fbbf24; --yellow-light: #221a09;
}
html, body {
  height: 100%; width: 100%; overflow: hidden; position: fixed; inset: 0;
  font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text);
  -webkit-tap-highlight-color: transparent;
}

/* ── LOBBY ── */
#lobby { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: var(--bg); z-index: 20; padding: 20px; overflow-y: auto; }
#lobby.hidden { display: none; }
.card { background: var(--surface); border: 1px solid var(--border); border-radius: 24px;
  padding: 32px 28px; width: 100%; max-width: 420px; box-shadow: 0 4px 24px rgba(0,0,0,.5); }
.logo { font-family: 'DM Serif Display', serif; font-size: 2rem; color: var(--text);
  display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
.logo-dot { width: 10px; height: 10px; background: var(--accent); border-radius: 50%; }
.tagline { font-size: .83rem; color: var(--muted); margin-bottom: 28px; font-weight: 500; }
.label { font-size: .72rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 6px; }
.inp { width: 100%; height: 46px; border: 1.5px solid var(--border); border-radius: 12px;
  padding: 0 14px; font-family: 'DM Sans', sans-serif; font-size: .95rem; font-weight: 600;
  color: var(--text); background: var(--bg); outline: none; transition: border-color .15s; margin-bottom: 16px; }
.inp:focus { border-color: var(--accent); }
.inp::placeholder { color: var(--muted); font-weight: 400; }
.divider { display: flex; align-items: center; gap: 10px; margin: 14px 0; }
.divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.divider span { font-size: .72rem; color: var(--muted); font-weight: 600; }
.btn { width: 100%; height: 46px; border-radius: 12px; border: none; font-family: 'DM Sans', sans-serif;
  font-size: .9rem; font-weight: 700; cursor: pointer; transition: opacity .15s; margin-bottom: 8px; }
.btn:active { opacity: .8; }
.btn:disabled { opacity: .35; cursor: not-allowed; }
.btn.primary { background: var(--text); color: var(--bg); }
.btn.accent { background: var(--accent); color: white; }
.btn.ghost { background: var(--surface); color: var(--text); border: 1.5px solid var(--border); }
.btn.success { background: var(--green); color: #0c2118; }
.row { display: flex; gap: 8px; }
.row .inp { flex: 1; margin-bottom: 0; }
.row .btn { width: auto; padding: 0 20px; margin-bottom: 0; }
.err { color: var(--red); font-size: .78rem; min-height: 18px; margin-top: -4px; margin-bottom: 8px; }

/* ── WAITING ── */
#waiting { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: var(--bg); z-index: 20; padding: 20px; overflow-y: auto; }
#waiting.hidden { display: none; }
.w-eyebrow { font-size: .72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 6px; }
.w-title { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--text); margin-bottom: 16px; }
.code-box { display: flex; align-items: center; gap: 10px; background: var(--bg);
  border: 1.5px solid var(--border); border-radius: 12px; padding: 12px 16px; margin-bottom: 16px; }
.code-label { font-size: .72rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
.code-val { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: var(--accent);
  letter-spacing: 6px; flex: 1; text-align: center; }
.copy-btn { background: none; border: 1px solid var(--border); border-radius: 8px;
  padding: 4px 10px; color: var(--muted); font-size: .72rem; font-weight: 600;
  cursor: pointer; transition: all .15s; }
.copy-btn:hover { border-color: var(--accent); color: var(--accent); }
.w-players { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; max-height: 200px; overflow-y: auto; }
.w-player { display: flex; align-items: center; gap: 10px; background: var(--bg);
  border: 1px solid var(--border); border-radius: 10px; padding: 8px 12px; }
.w-player.me { border-color: var(--accent); background: var(--accent-light); }
.w-av { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: .9rem; flex-shrink: 0; }
.w-name { font-weight: 600; font-size: .85rem; flex: 1; }
.host-badge { font-size: .65rem; font-weight: 700; background: var(--accent); color: white;
  border-radius: 100px; padding: 2px 7px; }
.submitted-badge { font-size: .65rem; font-weight: 700; background: var(--green); color: #0c2118;
  border-radius: 100px; padding: 2px 7px; }

/* Custom words toggle row */
.toggle-row { display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px; background: var(--bg); border: 1px solid var(--border);
  border-radius: 12px; margin-bottom: 12px; }
.toggle-label { font-size: .83rem; font-weight: 600; color: var(--text); }
.toggle-sub { font-size: .72rem; color: var(--muted); }
.toggle-switch { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider { position: absolute; inset: 0; background: var(--border2); border-radius: 24px;
  cursor: pointer; transition: background .2s; }
.toggle-slider::before { content: ''; position: absolute; width: 18px; height: 18px; left: 3px; top: 3px;
  background: white; border-radius: 50%; transition: transform .2s; }
.toggle-switch input:checked + .toggle-slider { background: var(--accent); }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(20px); }

/* Custom words input area */
#customWordsArea { margin-bottom: 14px; animation: fadeIn .2s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:none} }
.words-textarea { width: 100%; height: 80px; border: 1.5px solid var(--border); border-radius: 12px;
  padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: .88rem; font-weight: 500;
  color: var(--text); background: var(--bg); outline: none; resize: none;
  transition: border-color .15s; margin-bottom: 8px; }
.words-textarea:focus { border-color: var(--accent); }
.words-textarea::placeholder { color: var(--muted); }
.submit-status { font-size: .75rem; color: var(--green); min-height: 16px; margin-bottom: 8px; font-weight: 600; }

/* ── GAME ── */
/* position:fixed means the soft keyboard / viewport changes CANNOT affect layout */
#game { position: fixed; inset: 0; display: none; flex-direction: column; width: 100%; height: 100%; overflow: hidden; }
.header { display: flex; align-items: center; justify-content: space-between;
  padding: 10px 16px 8px; background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; }
.hlogo { font-family: 'DM Serif Display', serif; font-size: 1.25rem; color: var(--text);
  display: flex; align-items: center; gap: 7px; }
.hdot { width: 7px; height: 7px; background: var(--accent); border-radius: 50%; }
.pills { display: flex; gap: 6px; }
.pill { background: var(--bg); border: 1px solid var(--border); border-radius: 100px;
  padding: 3px 10px; font-size: .75rem; font-weight: 600; color: var(--muted);
  display: flex; align-items: center; gap: 4px; }
.pill strong { color: var(--text); }

.wordbar { display: flex; align-items: center; gap: 8px; padding: 8px 12px;
  background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; min-height: 52px; }
/* Hint tiles rendering */
#wHint { flex: 1; display: flex; align-items: center; justify-content: center;
  flex-wrap: wrap; gap: 5px; min-width: 0; overflow: hidden; }
.hint-word { display: flex; gap: 3px; flex-shrink: 0; }
.hint-ch { display: flex; align-items: flex-end; justify-content: center;
  min-width: 13px; height: 20px; font-family: 'DM Serif Display', serif;
  font-size: .82rem; font-weight: 700; color: var(--text); padding: 0 1px; line-height: 1; }
.hint-ch.blank { border-bottom: 2px solid var(--text); }
.hint-gap { width: 8px; flex-shrink: 0; }

.drawing-badge { font-size: .7rem; font-weight: 700; background: var(--accent); color: white;
  border-radius: 100px; padding: 2px 10px; white-space: nowrap; flex-shrink: 0; }
.drawing-badge.hidden { display: none; }

/* Vote buttons */
.vote-wrap { display: flex; gap: 4px; flex-shrink: 0; }
.vote-wrap.hidden { display: none; }
.vote-btn { height: 28px; padding: 0 8px; border-radius: 8px; border: 1.5px solid var(--border);
  background: var(--surface); font-size: .72rem; font-weight: 700; font-family: 'DM Sans', sans-serif;
  color: var(--muted); cursor: pointer; display: flex; align-items: center; gap: 3px;
  transition: all .15s; white-space: nowrap; }
.vote-btn:hover { border-color: var(--border2); color: var(--text); }
.vote-btn.like.on { border-color: var(--green); color: var(--green); background: var(--green-light); }
.vote-btn.dislike.on { border-color: var(--red); color: var(--red); background: #2a0f0f; }

.timer-wrap { flex-shrink: 0; width: 34px; height: 34px; position: relative; }
.timer-wrap svg { width: 34px; height: 34px; transform: rotate(-90deg); }
.track { fill: none; stroke: var(--border); stroke-width: 3; }
.tfill { fill: none; stroke: var(--accent); stroke-width: 3; stroke-linecap: round;
  transition: stroke-dashoffset .9s linear, stroke .3s; }
.tfill.red { stroke: var(--red); }
.tnum { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  font-size: .65rem; font-weight: 700; color: var(--text); }

/* Canvas area — fixed, never shifts */
.canvas-wrap {
  flex: 1; position: relative; background: #fff; overflow: hidden; min-height: 0;
}
canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: crosshair; touch-action: none; display: block; }

/* Canvas overlay */
.canvas-msg { position: absolute; inset: 0; display: flex; flex-direction: column;
  align-items: center; justify-content: center; background: rgba(17,17,19,.82);
  backdrop-filter: blur(6px); gap: 12px; z-index: 2; }
.canvas-msg.hidden { display: none; }
.canvas-msg-icon { font-size: 2.5rem; animation: pulse 1.4s ease-in-out infinite; }
@keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.15);opacity:.7} }
.canvas-msg-text { font-family: 'DM Serif Display', serif; font-size: 1.3rem; color: var(--text); }
.canvas-msg-sub { font-size: .82rem; color: var(--muted); font-weight: 500; }

.toolbar { background: var(--surface); border-top: 1px solid var(--border); padding: 8px 12px;
  display: flex; align-items: center; gap: 8px; flex-shrink: 0; overflow-x: auto; scrollbar-width: none; }
.toolbar::-webkit-scrollbar { display: none; }
.toolbar.off .color-swatch, .toolbar.off .sz-btn, .toolbar.off .tool-btn { opacity: .25; pointer-events: none; }
.colors { display: flex; gap: 5px; align-items: center; flex-shrink: 0; }
.color-swatch { width: 22px; height: 22px; border-radius: 50%; border: 2px solid transparent;
  cursor: pointer; transition: transform .12s, box-shadow .12s; flex-shrink: 0; outline: none; }
.color-swatch:hover { transform: scale(1.15); }
.color-swatch.on { border-color: var(--text); box-shadow: 0 0 0 2px var(--surface),0 0 0 4px var(--text); transform: scale(1.1); }
.vsep { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }
.sizes { display: flex; gap: 5px; align-items: center; flex-shrink: 0; }
.sz-btn { width: 28px; height: 28px; border-radius: 50%; border: 1.5px solid var(--border);
  background: var(--surface); cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: border-color .12s, background .12s; flex-shrink: 0; }
.sz-btn.on { border-color: var(--accent); background: var(--accent-light); }
.sz-btn .dot { border-radius: 50%; background: var(--text); pointer-events: none; }
.tools { display: flex; gap: 5px; margin-left: auto; flex-shrink: 0; }
.tool-btn { height: 28px; border-radius: 8px; border: 1.5px solid var(--border); background: var(--surface);
  cursor: pointer; font-size: .7rem; font-weight: 600; font-family: 'DM Sans', sans-serif;
  color: var(--muted); padding: 0 9px; display: flex; align-items: center; gap: 3px;
  transition: all .12s; white-space: nowrap; }
.tool-btn:hover { border-color: var(--border2); color: var(--text); }
.tool-btn.on { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
.tool-btn.danger:hover { border-color: var(--red); color: var(--red); }

.pstrip { display: flex; gap: 6px; padding: 6px 14px; background: var(--surface);
  border-top: 1px solid var(--border); overflow-x: auto; scrollbar-width: none; flex-shrink: 0; }
.pstrip::-webkit-scrollbar { display: none; }
.pchip { display: flex; align-items: center; gap: 5px; background: var(--bg);
  border: 1px solid var(--border); border-radius: 100px; padding: 3px 9px 3px 3px;
  white-space: nowrap; transition: border-color .2s; flex-shrink: 0; }
.pchip.me { border-color: var(--accent); background: var(--accent-light); }
.pchip.guessed { border-color: var(--green); background: var(--green-light); }
.pchip.drawing { border-color: var(--yellow); background: var(--yellow-light); }
.pchip-av { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: .72rem; flex-shrink: 0; }
.pchip-name { font-size: .72rem; font-weight: 600; color: var(--text); }
.pchip-score { font-size: .67rem; color: var(--muted); }

.chat-wrap { background: var(--surface); border-top: 1px solid var(--border);
  display: flex; flex-direction: column; flex-shrink: 0; }
.chat-msgs { overflow-y: auto; padding: 6px 12px; display: flex; flex-direction: column;
  gap: 3px; max-height: 100px; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.chat-msgs::-webkit-scrollbar { width: 3px; }
.chat-msgs::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
.msg { display: flex; gap: 5px; align-items: baseline; font-size: .78rem; line-height: 1.4;
  animation: msgIn .18s ease; }
@keyframes msgIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }
.msg.correct { color: var(--green); background: var(--green-light); padding: 3px 7px;
  border-radius: 7px; font-weight: 600; }
.msg.sys { color: var(--muted); font-style: italic; font-size: .73rem; }
.msg-name { font-weight: 700; color: var(--accent); flex-shrink: 0; }
.msg-name.me { color: var(--text); }
.chat-row { display: flex; gap: 7px; padding: 7px 12px; border-top: 1px solid var(--border); }
.chat-inp { flex: 1; height: 38px; border: 1.5px solid var(--border); border-radius: 10px;
  padding: 0 11px; font-family: 'DM Sans', sans-serif; font-size: .83rem; font-weight: 500;
  color: var(--text); background: var(--bg); outline: none; transition: border-color .15s; }
.chat-inp:focus { border-color: var(--accent); }
.chat-inp::placeholder { color: var(--muted); }
.send { height: 38px; padding: 0 14px; border-radius: 10px; border: none; background: var(--accent);
  color: white; font-family: 'DM Sans', sans-serif; font-size: .8rem; font-weight: 700;
  cursor: pointer; flex-shrink: 0; }

/* ── MODALS ── */
.overlay { position: fixed; inset: 0; background: rgba(10,10,12,.88); backdrop-filter: blur(12px);
  display: flex; align-items: center; justify-content: center; z-index: 50; padding: 20px; overflow-y: auto; }
.overlay.hidden { display: none; }
.modal { background: var(--surface); border: 1px solid var(--border); border-radius: 24px;
  padding: 26px 22px; width: 100%; max-width: 340px;
  box-shadow: 0 4px 24px rgba(0,0,0,.5); animation: pop .25s cubic-bezier(.34,1.56,.64,1); }
@keyframes pop { from{opacity:0;transform:scale(.93) translateY(10px)} to{opacity:1;transform:none} }
.meyebrow { font-size: .7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 5px; }
.mtitle { font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: var(--text); margin-bottom: 4px; }
.msub { font-size: .82rem; color: var(--muted); margin-bottom: 18px; font-weight: 500; }
.word-choices { display: flex; flex-direction: column; gap: 7px; }
.wchoice { width: 100%; padding: 13px 16px; border-radius: 12px; border: 1.5px solid var(--border);
  background: var(--surface); font-family: 'DM Serif Display', serif; font-size: 1.05rem;
  color: var(--text); text-align: left; cursor: pointer; transition: all .15s;
  display: flex; align-items: center; justify-content: space-between; }
.wchoice:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); transform: translateX(3px); }
.wchoice .arr { opacity: 0; transition: opacity .15s; }
.wchoice:hover .arr { opacity: 1; }
.the-word { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: var(--text); margin: 6px 0 18px; }
.score-rows { display: flex; flex-direction: column; gap: 5px; margin-bottom: 18px; max-height: 200px; overflow-y: auto; }
.score-row { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 10px;
  background: var(--bg); border: 1px solid var(--border); }
.score-row:first-child { border-color: var(--yellow); background: var(--yellow-light); }
.rank-badge { font-size: .95rem; width: 22px; text-align: center; flex-shrink: 0; }
.rank-name { flex: 1; font-weight: 600; font-size: .83rem; }
.rank-pts { font-weight: 700; font-size: .83rem; color: var(--accent); }

/* ── PODIUM (game over) ── */
.podium-wrap { display: flex; align-items: flex-end; justify-content: center; gap: 6px;
  margin: 16px 0 20px; padding: 0 4px; }
.podium-place { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; max-width: 96px; }
.podium-name { font-size: .78rem; font-weight: 700; text-align: center; color: var(--text);
  max-width: 90px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.podium-pts { font-size: .7rem; color: var(--muted); font-weight: 600; }
.podium-medal { font-size: 1.4rem; line-height: 1; }
.podium-block { display: flex; align-items: center; justify-content: center; width: 100%;
  border-radius: 10px 10px 0 0; font-size: .8rem; font-weight: 700; color: white;
  animation: riseUp .5s cubic-bezier(.34,1.3,.64,1) both; }
.podium-block.p1 { height: 80px; background: linear-gradient(180deg, #fbbf24, #d97706); animation-delay: .1s; }
.podium-block.p2 { height: 60px; background: linear-gradient(180deg, #9ca3af, #6b7280); animation-delay: .2s; }
.podium-block.p3 { height: 45px; background: linear-gradient(180deg, #a16207, #78350f); animation-delay: .3s; }
@keyframes riseUp { from{transform:scaleY(0);transform-origin:bottom} to{transform:scaleY(1);transform-origin:bottom} }
.podium-empty { color: var(--muted); font-size: .75rem; font-style: italic; text-align: center; margin-bottom: 12px; }

.toast { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%) scale(.85);
  background: var(--text); color: var(--bg); font-weight: 700; font-size: 1rem;
  padding: 11px 22px; border-radius: 100px; z-index: 100; pointer-events: none; opacity: 0;
  transition: all .2s cubic-bezier(.34,1.56,.64,1); white-space: nowrap; }
.toast.show { opacity: 1; transform: translate(-50%,-50%) scale(1); }
</style>
</head>
<body>

<!-- LOBBY -->
<div id="lobby">
  <div class="card">
    <div class="logo"><span class="logo-dot"></span> Scribble</div>
    <div class="tagline">Draw. Guess. Win. — Multiplayer</div>
    <div class="label">Your name</div>
    <input class="inp" id="nameInp" type="text" placeholder="Enter your name…" maxlength="20" autocomplete="off">
    <button class="btn accent" id="randomBtn">🎲 Play with random players</button>
    <div class="divider"><span>OR</span></div>
    <button class="btn ghost" id="createBtn" style="margin-bottom:10px">✦ Create private room</button>
    <div class="label">Join room with code</div>
    <div class="row">
      <input class="inp" id="codeInp" type="text" placeholder="ABC123" maxlength="6" autocomplete="off"
        style="text-transform:uppercase;letter-spacing:3px;font-family:'DM Serif Display',serif">
      <button class="btn ghost" id="joinBtn">Join →</button>
    </div>
    <div class="err" id="lobbyErr"></div>
  </div>
</div>

<!-- WAITING (private rooms) -->
<div id="waiting" class="hidden">
  <div class="card">
    <div class="w-eyebrow">Private Room</div>
    <div class="w-title">Waiting for players…</div>
    <div class="code-box">
      <div><div class="code-label">Room code</div><div class="code-val" id="codeVal">——</div></div>
      <button class="copy-btn" id="copyBtn">Copy</button>
    </div>
    <div class="w-players" id="wPlayers"></div>

    <!-- Custom Words Mode (shown to all, toggle for host) -->
    <div class="toggle-row" id="customToggleRow" style="display:none">
      <div>
        <div class="toggle-label">🎨 Custom Words Mode</div>
        <div class="toggle-sub">Everyone submits their own words</div>
      </div>
      <label class="toggle-switch">
        <input type="checkbox" id="customModeToggle">
        <span class="toggle-slider"></span>
      </label>
    </div>

    <!-- Custom words input (shown when mode enabled) -->
    <div id="customWordsArea" style="display:none">
      <div class="label">Your words (one per line, min 2 chars)</div>
      <textarea class="words-textarea" id="wordsInput" placeholder="volcano&#10;spaceship&#10;trombone" rows="3" maxlength="300"></textarea>
      <div class="submit-status" id="submitStatus"></div>
      <button class="btn ghost" id="submitWordsBtn" style="margin-bottom:12px">Submit words ✓</button>
    </div>

    <button class="btn accent" id="startBtn" disabled>Start game →</button>
    <button class="btn ghost" style="margin-top:8px" id="leaveBtn">Leave room</button>
  </div>
</div>

<!-- GAME -->
<div id="game">
  <header class="header">
    <div class="hlogo"><span class="hdot"></span> Scribble</div>
    <div class="pills">
      <div class="pill">Round <strong id="rNum">1</strong>/<strong id="rMax">3</strong></div>
      <div class="pill">⭐ <strong id="myScore">0</strong></div>
      <div class="pill" id="roomPill">——</div>
    </div>
  </header>

  <div class="wordbar">
    <div id="wHint">—</div>
    <span class="drawing-badge hidden" id="drawBadge">✏️ You're drawing</span>
    <!-- Vote buttons (hidden for drawer, visible for guessers during draw phase) -->
    <div class="vote-wrap hidden" id="voteWrap">
      <button class="vote-btn like" id="likeBtn">👍 <span id="likeCount">0</span></button>
      <button class="vote-btn dislike" id="dislikeBtn">👎 <span id="dislikeCount">0</span></button>
    </div>
    <div class="timer-wrap">
      <svg viewBox="0 0 36 36">
        <circle class="track" cx="18" cy="18" r="14"/>
        <circle class="tfill" id="tFill" cx="18" cy="18" r="14"/>
      </svg>
      <div class="tnum" id="tNum">60</div>
    </div>
  </div>

  <div class="canvas-wrap" id="canvasWrap">
    <canvas id="c"></canvas>
    <div class="canvas-msg" id="canvasMsg">
      <div class="canvas-msg-icon" id="canvasMsgIcon">🔍</div>
      <div class="canvas-msg-text" id="canvasMsgText">Finding a game…</div>
      <div class="canvas-msg-sub" id="canvasMsgSub">Connecting you with other players</div>
    </div>
  </div>

  <div class="toolbar" id="toolbar">
    <div class="colors" id="palette"></div>
    <div class="vsep"></div>
    <div class="sizes">
      <button class="sz-btn on" data-sz="3"><div class="dot" style="width:4px;height:4px"></div></button>
      <button class="sz-btn" data-sz="9"><div class="dot" style="width:9px;height:9px"></div></button>
      <button class="sz-btn" data-sz="18"><div class="dot" style="width:15px;height:15px"></div></button>
    </div>
    <div class="tools">
      <button class="tool-btn" id="eraserBtn">⌫ Erase</button>
      <button class="tool-btn" id="fillBtn">🪣 Fill</button>
      <button class="tool-btn danger" id="clearBtn">✕ Clear</button>
    </div>
  </div>

  <div class="pstrip" id="pstrip"></div>

  <div class="chat-wrap">
    <div class="chat-msgs" id="chatMsgs"></div>
    <div class="chat-row">
      <input class="chat-inp" id="chatInp" type="text" placeholder="Type your guess…" autocomplete="off" spellcheck="false">
      <button class="send" id="sendBtn">Send</button>
    </div>
  </div>
</div>

<!-- Word picker modal -->
<div class="overlay hidden" id="wordModal">
  <div class="modal">
    <div class="meyebrow">Your turn!</div>
    <div class="mtitle">Pick a word to draw</div>
    <div class="msub">Others will try to guess.</div>
    <div class="word-choices" id="wordChoices"></div>
  </div>
</div>

<!-- Round over modal -->
<div class="overlay hidden" id="roundModal">
  <div class="modal">
    <div class="meyebrow" id="rEyebrow">Round complete</div>
    <div class="mtitle" id="rTitle">Time's up!</div>
    <div class="msub">The word was</div>
    <div class="the-word" id="rWord"></div>
    <div class="score-rows" id="scoreRows"></div>
    <div style="color:var(--muted);font-size:.78rem;text-align:center">Next round starting…</div>
  </div>
</div>

<!-- Game over PODIUM modal -->
<div class="overlay hidden" id="podiumModal">
  <div class="modal" style="max-width:380px">
    <div class="meyebrow">🎉 Game Over!</div>
    <div class="mtitle">Final Standings</div>
    <div class="msub">The last word was <span id="podiumWord" style="color:var(--text);font-weight:700"></span></div>
    <div class="podium-wrap" id="podiumWrap"></div>
    <div class="score-rows" id="podiumRows"></div>
    <div style="color:var(--muted);font-size:.78rem;text-align:center;margin-top:4px">New game starting in a few seconds…</div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const COLORS = ['#1a1a18','#ffffff','#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#6b7280','#92400e','#065f46','#1e3a8a','#fde68a','#fed7aa'];
const CIRC = 2 * Math.PI * 14;

let socket, myId, myName, myRoomId, amDrawer = false;
let myVote = null; // 'like' | 'dislike' | null
let G = { color: '#1a1a18', size: 3, tool: 'pen', drawing: false, lx: 0, ly: 0 };
let lastState = null;
let currentPhase = 'lobby';

// ── Canvas ───────────────────────────────────────────────────────────
// LOGICAL canvas: fixed 800×600 — source of truth for all drawing.
// All coordinates (local + network) live in logical space.
// The display canvas just scales the offscreen image to fit the wrapper.
const LW = 800, LH = 600;

const offscreen = document.createElement('canvas');
offscreen.width = LW; offscreen.height = LH;
const offCtx = offscreen.getContext('2d');
offCtx.fillStyle = '#fff';
offCtx.fillRect(0, 0, LW, LH);

const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const DPR = window.devicePixelRatio || 1;

// Copy offscreen → display canvas. Called after every draw op and on resize.
function render() {
  ctx.setTransform(1, 0, 0, 1, 0, 0);
  ctx.drawImage(offscreen, 0, 0, LW, LH, 0, 0, canvas.width, canvas.height);
}

// Resize just updates display canvas size, then re-renders — zero data loss.
let resizeTimer = null;
function scheduleResize() {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(resizeCanvas, 60);
}

function resizeCanvas() {
  const wrap = document.getElementById('canvasWrap');
  const w = Math.floor(wrap.clientWidth);
  const h = Math.floor(wrap.clientHeight);
  if (w < 2 || h < 2) return;
  const nw = Math.round(w * DPR), nh = Math.round(h * DPR);
  if (canvas.width === nw && canvas.height === nh) return; // nothing changed
  canvas.width = nw; canvas.height = nh;
  canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
  render(); // paint offscreen content at new size — no data lost
}

// Returns touch/mouse position mapped to LOGICAL (0→LW, 0→LH) space.
function getPos(e) {
  const r = canvas.getBoundingClientRect();
  const s = e.touches ? e.touches[0] : e;
  return {
    x: (s.clientX - r.left) / r.width  * LW,
    y: (s.clientY - r.top)  / r.height * LH
  };
}

// Draw a stroke segment on the OFFSCREEN canvas.
function stroke(p, start) {
  if (G.tool === 'fill') return;
  const c = G.tool === 'eraser' ? '#fff' : G.color;
  if (start) {
    offCtx.beginPath(); offCtx.arc(p.x, p.y, G.size / 2, 0, Math.PI * 2);
    offCtx.fillStyle = c; offCtx.fill();
  } else {
    offCtx.beginPath(); offCtx.moveTo(G.lx, G.ly); offCtx.lineTo(p.x, p.y);
    offCtx.strokeStyle = c; offCtx.lineWidth = G.size;
    offCtx.lineCap = offCtx.lineJoin = 'round'; offCtx.stroke();
  }
  G.lx = p.x; G.ly = p.y;
  render();
}

// Replay a draw event received from the server (coords already in logical space).
function replayDraw(d) {
  if (d.type === 'start') {
    offCtx.beginPath(); offCtx.arc(d.x, d.y, d.size / 2, 0, Math.PI * 2);
    offCtx.fillStyle = d.color; offCtx.fill();
  } else {
    offCtx.beginPath(); offCtx.moveTo(d.lx, d.ly); offCtx.lineTo(d.x, d.y);
    offCtx.strokeStyle = d.color; offCtx.lineWidth = d.size;
    offCtx.lineCap = offCtx.lineJoin = 'round'; offCtx.stroke();
  }
  render();
}

function hexRgb(h) { return [parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16),255]; }
function colorMatch(a, b, t = 30) { return Math.abs(a[0]-b[0])+Math.abs(a[1]-b[1])+Math.abs(a[2]-b[2])+Math.abs(a[3]-b[3]) < t; }

// Flood fill on the OFFSCREEN canvas (logical coords).
function flood(sx, sy) {
  sx = Math.max(0, Math.min(LW - 1, Math.round(sx)));
  sy = Math.max(0, Math.min(LH - 1, Math.round(sy)));
  const imgd = offCtx.getImageData(0, 0, LW, LH), px = imgd.data;
  const I = (x, y) => (y * LW + x) * 4;
  const tgt = [px[I(sx,sy)], px[I(sx,sy)+1], px[I(sx,sy)+2], px[I(sx,sy)+3]];
  const fill = hexRgb(G.color);
  if (colorMatch(tgt, fill, 5)) return;
  const stack = [[sx, sy]], vis = new Uint8Array(LW * LH);
  while (stack.length) {
    const [x, y] = stack.pop();
    if (x < 0 || x >= LW || y < 0 || y >= LH || vis[y * LW + x]) continue;
    const i = I(x, y);
    if (!colorMatch([px[i], px[i+1], px[i+2], px[i+3]], tgt)) continue;
    vis[y * LW + x] = 1;
    px[i] = fill[0]; px[i+1] = fill[1]; px[i+2] = fill[2]; px[i+3] = fill[3];
    stack.push([x+1,y],[x-1,y],[x,y+1],[x,y-1]);
  }
  offCtx.putImageData(imgd, 0, 0);
  render();
}

function clearCanvas(emit) {
  offCtx.fillStyle = '#fff';
  offCtx.fillRect(0, 0, LW, LH);
  render();
  if (emit && socket) socket.emit('clearCanvas');
}

function onDrawStart(p) {
  if (!amDrawer) return;
  if (G.tool === 'fill') {
    flood(p.x, p.y);
    // Send logical coords — same for everyone
    socket?.emit('draw', { type: 'fill', x: p.x, y: p.y, color: G.color });
    return;
  }
  G.drawing = true; stroke(p, true);
  socket?.emit('draw', { type: 'start', x: p.x, y: p.y, color: G.tool === 'eraser' ? '#fff' : G.color, size: G.size });
}
function onDrawMove(p) {
  if (!amDrawer || !G.drawing || G.tool === 'fill') return;
  const c = G.tool === 'eraser' ? '#fff' : G.color;
  socket?.emit('draw', { type: 'move', x: p.x, y: p.y, lx: G.lx, ly: G.ly, color: c, size: G.size });
  stroke(p, false);
}
canvas.addEventListener('mousedown', e => onDrawStart(getPos(e)));
canvas.addEventListener('mousemove', e => { if (G.drawing) onDrawMove(getPos(e)); });
canvas.addEventListener('mouseup', () => G.drawing = false);
canvas.addEventListener('mouseleave', () => G.drawing = false);
canvas.addEventListener('touchstart', e => { e.preventDefault(); onDrawStart(getPos(e)); }, { passive: false });
canvas.addEventListener('touchmove', e => { e.preventDefault(); if (G.drawing) onDrawMove(getPos(e)); }, { passive: false });
canvas.addEventListener('touchend', () => G.drawing = false);

// ── Toolbar ───────────────────────────────────────────────────────────
function initToolbar() {
  const pal = document.getElementById('palette');
  COLORS.forEach((c, i) => {
    const b = document.createElement('button');
    b.className = 'color-swatch' + (i === 0 ? ' on' : '');
    b.style.background = c;
    if (c === '#ffffff') b.style.boxShadow = 'inset 0 0 0 1px #3a3a3f';
    if (c === '#1a1a18') b.style.boxShadow = 'inset 0 0 0 1px #6b6b72';
    b.onclick = () => {
      document.querySelectorAll('.color-swatch').forEach(x => x.classList.remove('on'));
      b.classList.add('on'); G.color = c; setTool('pen');
    };
    pal.appendChild(b);
  });
  document.querySelectorAll('.sz-btn').forEach(b => {
    b.onclick = () => {
      document.querySelectorAll('.sz-btn').forEach(x => x.classList.remove('on'));
      b.classList.add('on'); G.size = +b.dataset.sz;
    };
  });
  document.getElementById('eraserBtn').onclick = () => setTool(G.tool === 'eraser' ? 'pen' : 'eraser');
  document.getElementById('fillBtn').onclick = () => setTool(G.tool === 'fill' ? 'pen' : 'fill');
  document.getElementById('clearBtn').onclick = () => clearCanvas(true);
}

function setTool(t) {
  G.tool = t;
  document.getElementById('eraserBtn').classList.toggle('on', t === 'eraser');
  document.getElementById('fillBtn').classList.toggle('on', t === 'fill');
  canvas.style.cursor = (t === 'fill' || t === 'eraser') ? 'cell' : 'crosshair';
}

function setDrawer(yes) {
  amDrawer = yes;
  document.getElementById('toolbar').classList.toggle('off', !yes);
  document.getElementById('drawBadge').classList.toggle('hidden', !yes);
  canvas.style.pointerEvents = yes ? 'auto' : 'none';
  const inp = document.getElementById('chatInp');
  const btn = document.getElementById('sendBtn');
  if (yes) {
    inp.disabled = true;
    inp.placeholder = 'You are drawing…';
    btn.disabled = true;
    btn.style.opacity = '0.3';
    // Hide vote buttons for drawer
    document.getElementById('voteWrap').classList.add('hidden');
    myVote = null;
  } else {
    inp.disabled = false;
    inp.placeholder = 'Type your guess…';
    btn.disabled = false;
    btn.style.opacity = '';
  }
}

function setVoteVisible(visible) {
  if (amDrawer) return; // never show for drawer
  document.getElementById('voteWrap').classList.toggle('hidden', !visible);
  if (!visible) {
    myVote = null;
    document.getElementById('likeBtn').classList.remove('on');
    document.getElementById('dislikeBtn').classList.remove('on');
    document.getElementById('likeCount').textContent = '0';
    document.getElementById('dislikeCount').textContent = '0';
  }
}

// ── Hint rendering ────────────────────────────────────────────────────
// Renders hint string (e.g. "_ _ _   _ _ _") as letter tiles
function renderHint(hintStr) {
  const el = document.getElementById('wHint');
  el.innerHTML = '';
  // Split on 3+ spaces to get word groups
  const groups = hintStr.split(/   +/);
  groups.forEach((g, gi) => {
    if (gi > 0) {
      const gap = document.createElement('span');
      gap.className = 'hint-gap';
      el.appendChild(gap);
    }
    const wordEl = document.createElement('div');
    wordEl.className = 'hint-word';
    g.trim().split(' ').forEach(c => {
      const ch = document.createElement('span');
      ch.className = 'hint-ch' + (c === '_' ? ' blank' : '');
      ch.textContent = c === '_' ? '' : c;
      wordEl.appendChild(ch);
    });
    el.appendChild(wordEl);
  });
}

// Renders the actual word (for drawer) as tiles with all letters revealed
function renderWord(word) {
  const el = document.getElementById('wHint');
  el.innerHTML = '';
  word.split(' ').forEach((w, wi) => {
    if (wi > 0) {
      const gap = document.createElement('span');
      gap.className = 'hint-gap';
      el.appendChild(gap);
    }
    const wordEl = document.createElement('div');
    wordEl.className = 'hint-word';
    w.split('').forEach(c => {
      const ch = document.createElement('span');
      ch.className = 'hint-ch';
      ch.textContent = c;
      wordEl.appendChild(ch);
    });
    el.appendChild(wordEl);
  });
}

// ── Canvas overlay message ────────────────────────────────────────────
function setCanvasMsg(icon, text, sub) {
  const el = document.getElementById('canvasMsg');
  if (!icon) { el.classList.add('hidden'); return; }
  el.classList.remove('hidden');
  document.getElementById('canvasMsgIcon').textContent = icon;
  document.getElementById('canvasMsgText').textContent = text;
  document.getElementById('canvasMsgSub').textContent = sub || '';
}

// ── Players strip ─────────────────────────────────────────────────────
function renderPlayers(state) {
  if (!state) return;
  const strip = document.getElementById('pstrip');
  strip.innerHTML = '';
  const d = state.players[state.drawerIdx % Math.max(state.players.length, 1)];
  state.players.forEach(p => {
    const isMe = p.id === myId, isDr = d && p.id === d.id;
    const chip = document.createElement('div');
    chip.className = 'pchip' + (isMe ? ' me' : '') + (p.guessed ? ' guessed' : '') + (isDr && state.phase === 'draw' ? ' drawing' : '');
    chip.innerHTML = `<div class="pchip-av" style="background:${p.bg}">${p.avatar}</div>` +
      `<div><div class="pchip-name">${p.name}${isDr && state.phase === 'draw' ? ' ✏️' : ''}${p.guessed ? ' ✓' : ''}</div>` +
      `<div class="pchip-score">${p.score} pts</div></div>`;
    strip.appendChild(chip);
  });
}

// ── Chat ──────────────────────────────────────────────────────────────
const MAX_MSGS = 80;
function addMsg(name, text, cls) {
  const box = document.getElementById('chatMsgs');
  // Limit chat message count
  while (box.children.length >= MAX_MSGS) box.removeChild(box.firstChild);
  const div = document.createElement('div');
  div.className = 'msg' + (cls ? ' ' + cls : '');
  if (cls === 'sys') div.textContent = text;
  else div.innerHTML = `<span class="msg-name${name === myName ? ' me' : ''}">${name}</span><span> ${text}</span>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

// ── Timer ─────────────────────────────────────────────────────────────
function setTimer(t, total = 60) {
  document.getElementById('tNum').textContent = t;
  const f = document.getElementById('tFill');
  f.style.strokeDasharray = CIRC;
  f.style.strokeDashoffset = CIRC * (1 - t / total);
  f.classList.toggle('red', t <= 10);
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 1600);
}

// ── Podium ────────────────────────────────────────────────────────────
function renderPodium(scores, word) {
  document.getElementById('podiumWord').textContent = word;
  const wrap = document.getElementById('podiumWrap');
  wrap.innerHTML = '';
  const rows = document.getElementById('podiumRows');
  rows.innerHTML = '';

  // Podium: 2nd left, 1st center, 3rd right
  const podiumOrder = [1, 0, 2]; // index into scores
  const medals = ['🥇', '🥈', '🥉'];
  const blockClass = ['p1', 'p2', 'p3'];
  const positions = [1, 0, 2]; // display order

  // Build 3-place podium
  const podiumData = podiumOrder.map((si, pi) => ({
    score: scores[si],
    medal: medals[si],
    blockCls: blockClass[si],
    displayPos: pi
  }));

  // Sort so we show: 2nd(left), 1st(center), 3rd(right)
  const displayOrder = [
    { si: 1, blockCls: 'p2', medal: '🥈' },
    { si: 0, blockCls: 'p1', medal: '🥇' },
    { si: 2, blockCls: 'p3', medal: '🥉' }
  ];

  displayOrder.forEach(({ si, blockCls, medal }) => {
    const p = scores[si];
    const place = document.createElement('div');
    place.className = 'podium-place';
    if (p) {
      place.innerHTML = `
        <div class="podium-medal">${medal}</div>
        <div class="podium-name">${p.name}</div>
        <div class="podium-pts">${p.score} pts</div>
        <div class="podium-block ${blockCls}">${si + 1}</div>
      `;
    } else {
      place.innerHTML = `<div class="podium-block ${blockCls}" style="opacity:.3">—</div>`;
    }
    wrap.appendChild(place);
  });

  // Full score list below
  scores.forEach((p, i) => {
    const r = document.createElement('div');
    r.className = 'score-row';
    r.innerHTML = `<span class="rank-badge">${medals[i] || '#' + (i+1)}</span><span class="rank-name">${p.name}</span><span class="rank-pts">${p.score} pts</span>`;
    rows.appendChild(r);
  });
}

// ── Waiting room ──────────────────────────────────────────────────────
function renderWaiting(state) {
  if (!state) return;
  const c = document.getElementById('wPlayers');
  c.innerHTML = '';
  const submittedIds = state.wordsSubmitted || [];
  state.players.forEach((p, i) => {
    const d = document.createElement('div');
    d.className = 'w-player' + (p.id === myId ? ' me' : '');
    const hasSubmitted = submittedIds.includes(p.id);
    d.innerHTML = `<div class="w-av" style="background:${p.bg}">${p.avatar}</div>` +
      `<div class="w-name">${p.name}${p.id === myId ? ' (you)' : ''}</div>` +
      (i === 0 ? '<span class="host-badge">Host</span>' : '') +
      (state.customMode && hasSubmitted ? '<span class="submitted-badge">✓ Words</span>' : '');
    c.appendChild(d);
  });

  const isHost = state.players[0]?.id === myId;

  // Show custom words toggle row (always visible in private waiting room)
  const toggleRow = document.getElementById('customToggleRow');
  toggleRow.style.display = 'flex';
  // Only host can toggle
  document.getElementById('customModeToggle').disabled = !isHost;
  document.getElementById('customModeToggle').checked = state.customMode;

  // Show/hide custom words input area
  const customArea = document.getElementById('customWordsArea');
  customArea.style.display = state.customMode ? 'block' : 'none';

  // Show submit status
  if (state.customMode) {
    const mySubmitted = submittedIds.includes(myId);
    document.getElementById('submitStatus').textContent = mySubmitted ? '✓ Words submitted!' : '';
    const submittedCount = submittedIds.length;
    const totalPlayers = state.players.length;
    document.getElementById('submitStatus').textContent = mySubmitted
      ? `✓ Your words submitted! (${submittedCount}/${totalPlayers} players ready)`
      : `${submittedCount}/${totalPlayers} players submitted`;
  }

  // Enable start only for host with 2+ players
  const startBtn = document.getElementById('startBtn');
  startBtn.disabled = !isHost || state.players.length < 2;
}

// ── Screens ───────────────────────────────────────────────────────────
function goLobby() {
  document.getElementById('lobby').classList.remove('hidden');
  document.getElementById('waiting').classList.add('hidden');
  document.getElementById('game').style.display = 'none';
  // Reset UI state
  myVote = null;
}

function goWaiting(roomId) {
  document.getElementById('lobby').classList.add('hidden');
  document.getElementById('waiting').classList.remove('hidden');
  document.getElementById('game').style.display = 'none';
  document.getElementById('codeVal').textContent = roomId;
}

function goGame() {
  document.getElementById('lobby').classList.add('hidden');
  document.getElementById('waiting').classList.add('hidden');
  const game = document.getElementById('game');
  game.style.display = 'flex';
  document.getElementById('roomPill').textContent = myRoomId || '——';
  // Two RAF calls ensure the flex layout has fully resolved before we measure
  requestAnimationFrame(() => requestAnimationFrame(() => resizeCanvas()));
  requestFullscreen();
}

function requestFullscreen() {
  const el = document.documentElement;
  const req = el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen || el.msRequestFullscreen;
  if (req) req.call(el).catch(() => {});
  if (screen.orientation && screen.orientation.lock) {
    screen.orientation.lock('portrait').catch(() => {});
  }
  history.pushState({ inGame: true }, '');
}

// ── Socket ────────────────────────────────────────────────────────────
function connect(cb) {
  if (socket?.connected) { cb(); return; }
  // Disconnect any existing socket
  if (socket) { socket.removeAllListeners(); socket.disconnect(); }

  socket = io('https://scribble-mbha.onrender.com', {
    transports: ['websocket', 'polling'],
    reconnectionAttempts: 5,
    reconnectionDelay: 1000
  });

  socket.on('connect', () => {
    myId = socket.id;
    cb();
  });
  socket.on('connect_error', () => showErr('Cannot connect to server'));
  socket.on('disconnect', (reason) => {
    if (reason !== 'io client disconnect') {
      // Show reconnecting overlay
      const gameVisible = document.getElementById('game').style.display !== 'none';
      if (gameVisible) setCanvasMsg('📡', 'Reconnecting…', 'Please wait');
    }
  });
  socket.on('reconnect', () => {
    setCanvasMsg('✅', 'Reconnected!', '');
    setTimeout(() => setCanvasMsg(null), 1500);
  });

  socket.on('err', msg => showErr(msg));

  socket.on('state', state => {
    lastState = state;
    currentPhase = state.phase;
    renderPlayers(state);
    document.getElementById('rNum').textContent = state.round;
    document.getElementById('rMax').textContent = state.maxRounds;

    const d = state.players[state.drawerIdx % Math.max(state.players.length, 1)];

    // Auto-transition from waiting screen to game if game has started
    const onWaiting = !document.getElementById('waiting').classList.contains('hidden');
    if (onWaiting && state.phase !== 'lobby') {
      goGame();
    }

    // Update waiting room UI if still there
    if (!document.getElementById('waiting').classList.contains('hidden')) {
      renderWaiting(state);
    }

    if (state.phase === 'draw') {
      setDrawer(d?.id === myId);
      if (d?.id !== myId) {
        setCanvasMsg(null);
        setVoteVisible(true);
      }
    } else if (state.phase === 'choose') {
      setDrawer(false);
      setVoteVisible(false);
      if (d && d.id !== myId) {
        setCanvasMsg('🤔', `${d.name} is choosing…`, 'Get ready to guess!');
      }
    } else if (state.phase === 'lobby') {
      setDrawer(false);
      setVoteVisible(false);
      renderWaiting(state);
    }
  });

  socket.on('gameStarting', () => {
    // All players (including non-host on waiting screen) transition to game
    goGame();
    setCanvasMsg('⏳', 'Game starting…', '');
  });

  socket.on('gameActive', ({ phase }) => {
    if (phase === 'draw') {
      if (!amDrawer) setCanvasMsg(null);
      setVoteVisible(!amDrawer);
    } else if (phase === 'choose') {
      setVoteVisible(false);
    }
  });

  socket.on('sys', text => {
    addMsg('', text, 'sys');
    const gameVisible = document.getElementById('game').style.display !== 'none';
    if (gameVisible && (currentPhase === 'lobby' || !lastState)) {
      setCanvasMsg('👥', 'Waiting for players…', text);
    }
  });

  socket.on('hint', h => {
    if (!amDrawer) {
      renderHint(h);
    }
    setCanvasMsg(null);
  });

  socket.on('tick', t => setTimer(t, lastState?.totalTime || 60));

  socket.on('pickWord', ({ words, round, max }) => {
    goGame();
    document.getElementById('rNum').textContent = round;
    document.getElementById('rMax').textContent = max;
    const c = document.getElementById('wordChoices');
    c.innerHTML = '';
    words.forEach(w => {
      const b = document.createElement('button');
      b.className = 'wchoice';
      b.innerHTML = `<span>${w}</span><span class="arr">→</span>`;
      b.onclick = () => {
        socket.emit('wordPicked', { word: w });
        document.getElementById('wordModal').classList.add('hidden');
      };
      c.appendChild(b);
    });
    document.getElementById('wordModal').classList.remove('hidden');
    setDrawer(true);
    setCanvasMsg(null);
    setVoteVisible(false);
  });

  socket.on('yourWord', w => {
    renderWord(w);
    setCanvasMsg(null);
  });

  socket.on('draw', d => {
    if (d.type === 'fill') {
      // x,y are already in logical space (0→LW, 0→LH)
      const ox = G.color; G.color = d.color;
      flood(d.x, d.y);
      G.color = ox;
    } else {
      replayDraw(d);
    }
  });

  socket.on('clearCanvas', () => clearCanvas(false));

  socket.on('chat', ({ name, text }) => addMsg(name, text));

  socket.on('correct', ({ name, pts }) => {
    addMsg(name, `guessed the word! +${pts} pts`, 'correct');
    if (name === myName) {
      toast(`✓ +${pts} pts!`);
      const cur = parseInt(document.getElementById('myScore').textContent) || 0;
      document.getElementById('myScore').textContent = cur + pts;
    }
  });

  socket.on('voteUpdate', ({ likes, dislikes }) => {
    document.getElementById('likeCount').textContent = likes;
    document.getElementById('dislikeCount').textContent = dislikes;
  });

  socket.on('roundOver', ({ word, round, max, isLast, scores }) => {
    G.drawing = false;
    setDrawer(false);
    setVoteVisible(false);
    myVote = null;
    document.getElementById('wordModal').classList.add('hidden');

    if (isLast) {
      // Show special podium
      renderPodium(scores, word);
      document.getElementById('podiumModal').classList.remove('hidden');
      document.getElementById('myScore').textContent = '0';
      setCanvasMsg('🏆', 'Game Over!', `The word was: ${word}`);
      setTimeout(() => {
        document.getElementById('podiumModal').classList.add('hidden');
      }, 7000);
    } else {
      // Regular round over
      document.getElementById('rWord').textContent = word;
      document.getElementById('rEyebrow').textContent = `Round ${round} of ${max}`;
      document.getElementById('rTitle').textContent = "Time's up!";
      const medals = ['🥇', '🥈', '🥉'];
      const rows = document.getElementById('scoreRows');
      rows.innerHTML = '';
      scores.forEach((p, i) => {
        const r = document.createElement('div'); r.className = 'score-row';
        r.innerHTML = `<span class="rank-badge">${medals[i] || '#'+(i+1)}</span><span class="rank-name">${p.name}</span><span class="rank-pts">${p.score} pts</span>`;
        rows.appendChild(r);
      });
      document.getElementById('roundModal').classList.remove('hidden');
      setCanvasMsg('⏳', 'Round over!', `The word was: ${word}`);
      setTimeout(() => {
        document.getElementById('roundModal').classList.add('hidden');
      }, 5800);
    }
  });
}

// ── Lobby actions ─────────────────────────────────────────────────────
function getName() {
  const n = document.getElementById('nameInp').value.trim();
  if (!n) { showErr('Enter your name first!'); return null; }
  return n;
}
function showErr(msg) {
  document.getElementById('lobbyErr').textContent = msg;
  setTimeout(() => document.getElementById('lobbyErr').textContent = '', 3000);
}

document.getElementById('randomBtn').onclick = () => {
  const name = getName(); if (!name) return;
  myName = name;
  connect(() => {
    goGame();
    setCanvasMsg('🔍', 'Finding a game…', 'Connecting you with other players');
    setDrawer(false);
    socket.emit('joinRandom', { name });
    socket.once('joined', ({ roomId, inProgress, phase }) => {
      myRoomId = roomId;
      document.getElementById('roomPill').textContent = roomId;
      if (inProgress && (phase === 'draw' || phase === 'choose')) {
        setCanvasMsg('🎨', 'Joined a game in progress!', 'Watch and guess this round');
        addMsg('', 'You joined a game in progress!', 'sys');
      } else {
        setCanvasMsg('👥', 'Waiting for players…', 'Share the code to invite friends');
        addMsg('', 'Waiting for another player to join…', 'sys');
      }
    });
  });
};

document.getElementById('createBtn').onclick = () => {
  const name = getName(); if (!name) return;
  myName = name;
  connect(() => {
    socket.emit('createRoom', { name });
    socket.once('joined', ({ roomId }) => {
      myRoomId = roomId;
      goWaiting(roomId);
    });
  });
};

document.getElementById('joinBtn').onclick = () => {
  const name = getName(); if (!name) return;
  const code = document.getElementById('codeInp').value.trim().toUpperCase();
  if (code.length < 4) { showErr('Enter a valid room code'); return; }
  myName = name;
  connect(() => {
    socket.emit('joinRoom', { roomId: code, name });
    socket.once('joined', ({ roomId, inProgress, phase }) => {
      myRoomId = roomId;
      if (inProgress) {
        goGame();
        setCanvasMsg('🎨', 'Joined a game in progress!', 'Watch and guess this round');
        addMsg('', 'You joined a game in progress!', 'sys');
      } else {
        goWaiting(roomId);
      }
    });
  });
};

document.getElementById('codeInp').addEventListener('input', e => e.target.value = e.target.value.toUpperCase());

document.getElementById('copyBtn').onclick = () => {
  navigator.clipboard.writeText(myRoomId).then(() => {
    document.getElementById('copyBtn').textContent = 'Copied!';
    setTimeout(() => document.getElementById('copyBtn').textContent = 'Copy', 1500);
  });
};

document.getElementById('startBtn').onclick = () => {
  socket?.emit('startGame');
};

document.getElementById('leaveBtn').onclick = () => {
  socket?.disconnect(); socket = null;
  const exit = document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen || document.msExitFullscreen;
  if (exit && document.fullscreenElement) exit.call(document).catch(() => {});
  goLobby();
};

// Custom words mode toggle (host only)
document.getElementById('customModeToggle').onchange = (e) => {
  socket?.emit('setCustomMode', { enabled: e.target.checked });
};

document.getElementById('submitWordsBtn').onclick = () => {
  const raw = document.getElementById('wordsInput').value;
  const words = raw.split('\n').map(w => w.trim()).filter(w => w.length >= 2);
  if (words.length === 0) { return; }
  socket?.emit('submitWords', { words });
  document.getElementById('submitStatus').textContent = `✓ Submitted ${words.length} word${words.length !== 1 ? 's' : ''}!`;
};

// Vote buttons
document.getElementById('likeBtn').onclick = () => {
  if (!socket) return;
  const newVote = myVote === 'like' ? null : 'like';
  myVote = newVote;
  socket.emit('vote', { type: newVote || 'none' });
  document.getElementById('likeBtn').classList.toggle('on', newVote === 'like');
  document.getElementById('dislikeBtn').classList.remove('on');
};

document.getElementById('dislikeBtn').onclick = () => {
  if (!socket) return;
  const newVote = myVote === 'dislike' ? null : 'dislike';
  myVote = newVote;
  socket.emit('vote', { type: newVote || 'none' });
  document.getElementById('dislikeBtn').classList.toggle('on', newVote === 'dislike');
  document.getElementById('likeBtn').classList.remove('on');
};

// Chat
document.getElementById('sendBtn').onclick = sendMsg;
document.getElementById('chatInp').addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });
function sendMsg() {
  const inp = document.getElementById('chatInp');
  const v = inp.value.trim(); inp.value = '';
  if (!v || !socket) return;
  socket.emit('guess', { text: v });
}

// Prevent accidental back navigation during game
window.addEventListener('popstate', () => {
  if (document.getElementById('game').style.display !== 'none') {
    history.pushState({ inGame: true }, '');
  }
});

// ── Init ──────────────────────────────────────────────────────────────
// Use window resize + orientation change for canvas resizing.
// We deliberately do NOT use ResizeObserver on canvasWrap, because on mobile
// the soft keyboard triggers it constantly, causing the canvas to flicker/shift.
// With the offscreen canvas approach, resize is now safe (zero data loss) but
// we still limit it to real device-level changes only.
window.addEventListener('resize', () => {
  // Only resize if we're actually in-game
  if (document.getElementById('game').style.display !== 'none') {
    scheduleResize();
  }
});
window.addEventListener('orientationchange', () => {
  setTimeout(resizeCanvas, 200);
});

initToolbar();
resizeCanvas();
document.getElementById('tFill').style.strokeDasharray = CIRC;
document.getElementById('tFill').style.strokeDashoffset = 0;
</script>
</body>
</html>
